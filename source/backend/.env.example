# ========================================
# 轻量级客户订单管理系统 — 环境配置模板
# ========================================
# 使用方式：复制此文件为 .env，填入实际值
# cp .env.example .env
# 注意：.env 文件已加入 .gitignore，不会提交到代码仓库
# ========================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=你的数据库密码
DB_DATABASE=mycrm

# JWT 配置
# JWT_SECRET 请使用强随机字符串，不要使用示例值
# 生成命令: openssl rand -base64 32
JWT_SECRET=请替换为随机密钥
JWT_EXPIRES_IN=24h

# 应用配置
PORT=3000
